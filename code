import heapq

def print_state(state):
    for i in range(0, 9, 3):
        print(state[i:i+3])
    print()

def manhattan(state, goal):
    distance = 0
    for num in range(1, 9):
        i = state.index(num)
        j = goal.index(num)

        x1, y1 = divmod(i, 3)
        x2, y2 = divmod(j, 3)

        distance += abs(x1 - x2) + abs(y1 - y2)
    return distance

def get_next_states(state):
    pos = state.index(0)

    moves = {
        0:[1,3], 1:[0,2,4], 2:[1,5],
        3:[0,4,6], 4:[1,3,5,7], 5:[2,4,8],
        6:[3,7], 7:[4,6,8], 8:[5,7]
    }

    states = []

    for move in moves[pos]:
        new_state = state[:]
        new_state[pos], new_state[move] = new_state[move], new_state[pos]
        states.append(new_state)

    return states

def astar(initial, goal):
    pq = []
    visited = []

    g = 0
    h = manhattan(initial, goal)
    f = g + h

    heapq.heappush(pq, (f, g, initial, []))

    while pq:
        f, g, current, path = heapq.heappop(pq)

        if current in visited:
            continue

        visited.append(current)

        path = path + [current]

        if current == goal:
            return path

        for next_state in get_next_states(current):
            if next_state not in visited:
                new_g = g + 1
                new_h = manhattan(next_state, goal)
                new_f = new_g + new_h

                heapq.heappush(pq, (new_f, new_g, next_state, path))

    return None

initial = list(map(int, input("Enter initial state: ").split()))
goal = list(map(int, input("Enter goal state: ").split()))

result = astar(initial, goal)

if result:
    print("Solution Path:\n")
    for step in result:
        print_state(step)
else:
    print("No Solution Found")

