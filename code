def manhattan(state, goal):
    distance = 0

    for num in range(1, 9):
        i = state.index(num)
        j = goal.index(num)

        x1, y1 = divmod(i, 3)
        x2, y2 = divmod(j, 3)

        distance += abs(x1-x2) + abs(y1-y2)

    return distance

def hamming(state, goal):
    count = 0

    for i in range(9):
        if state[i] != 0 and state[i] != goal[i]:
            count += 1

    return count

